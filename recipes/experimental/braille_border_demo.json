{
  "schema_version": 1,
  "id": "experimental.braille_border",
  "title": "Braille Border Demo",
  "description": "Demonstration of custom braille character borders. Uses Unicode braille patterns for a dotted, artistic border effect.",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
    "message": "⠿ Custom braille borders ⠿",
    "layout": {
      "width": 32,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8000
    },
    "border": {
      "type": "rounded",
      "trim": "none",
      "custom_chars": {
        "top_left": "⣏",
        "top_right": "⣹",
        "bottom_left": "⡏",
        "bottom_right": "⡹",
        "horizontal_top": "⠒",
        "horizontal_bottom": "⣀",
        "vertical_left": "⡇",
        "vertical_right": "⢸"
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 600,
        "easing": "sine_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 400,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "dissolve",
          "seed": 42,
          "chunk_size": 1
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 200,
            "g": 230,
            "b": 255
          },
          "background": {
            "type": "rgb",
            "r": 30,
            "g": 40,
            "b": 60
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "band_width": 4,
            "speed": 0.5,
            "angle_deg": 45.0,
            "head": {
              "type": "rgb",
              "r": 150,
              "g": 200,
              "b": 255
            },
            "tail": {
              "type": "rgb",
              "r": 100,
              "g": 160,
              "b": 220
            }
          }
        },
        "exit_effect": null
      }
    }
  }
}
