{
  "schema_version": 1,
  "id": "experimental.matte_shadow",
  "title": "Matte Shadow Demo",
  "description": "Picture frame with matte and drop shadow. Uses partial blocks to create depth: frame (FG), matte (BG), and shadow offset.",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
    "message": "Framed with shadow",
    "layout": {
      "width": 26,
      "height": 5,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8000
    },
    "border": {
      "type": "none",
      "frame": {
        "top_left": "▛",
        "top_right": "▜",
        "bottom_left": "▙",
        "bottom_right": "▟",
        "top": "▀",
        "bottom": "▄",
        "left": "▌",
        "right": "▐"
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 500,
        "easing": "sine_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 400,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "dissolve",
          "chunk_size": 2,
          "seed": 42
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 60,
            "g": 60,
            "b": 70
          },
          "background": {
            "type": "rgb",
            "r": 240,
            "g": 235,
            "b": 225
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": null,
        "exit_effect": null
      }
    }
  }
}
