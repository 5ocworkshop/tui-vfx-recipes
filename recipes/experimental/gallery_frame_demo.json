{
  "schema_version": 1,
  "id": "experimental.gallery_frame",
  "title": "Gallery Frame Demo",
  "description": "Picture frame effect using partial block characters. Frame edge shows through FG, matte shows through BG.",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
    "message": "Like a framed photo",
    "layout": {
      "width": 28,
      "height": 5,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8000
    },
    "border": {
      "type": "none",
      "frame": {
        "top_left": "▗",
        "top_right": "▖",
        "bottom_left": "▝",
        "bottom_right": "▘",
        "top": "▄",
        "bottom": "▀",
        "left": "▐",
        "right": "▌"
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 600,
        "easing": "sine_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 400,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 139,
            "g": 90,
            "b": 43
          },
          "background": {
            "type": "rgb",
            "r": 245,
            "g": 235,
            "b": 220
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": null,
        "exit_effect": null
      }
    }
  }
}
