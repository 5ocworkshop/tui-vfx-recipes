{
  "schema_version": 1,
  "id": "experimental.speech_bubble",
  "title": "Speech Bubble Demo",
  "description": "Tooltip-style notification with arrow pointer. Uses custom frame to create non-rectangular appearance.",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
    "message": "Hey, look at this!",
    "layout": {
      "width": 26,
      "height": 4,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 6000
    },
    "border": {
      "type": "none",
      "frame": {
        "top_left": "╭",
        "top_right": "╮",
        "bottom_left": "╰",
        "bottom_right": "◄",
        "top": "─",
        "bottom": "─",
        "left": "│",
        "right": "│"
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 400,
        "easing": "back_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 300,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 50,
            "g": 50,
            "b": 50
          },
          "background": {
            "type": "rgb",
            "r": 255,
            "g": 255,
            "b": 230
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": null,
        "exit_effect": null
      }
    }
  }
}
