{
  "schema_version": 1,
  "id": "debug.content.odometer",
  "title": "Debug: Content - Odometer",
  "description": "Tests Odometer content effect for vertical scrolling digits",
  "version": "1.0.0",
  "last_updated": "2025-12-30",
  "config": {
