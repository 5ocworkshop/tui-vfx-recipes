      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 0,
            "g": 255,
            "b": 100
          },
          "background": {
            "type": "rgb",
            "r": 10,
            "g": 20,
            "b": 10
          }
        },
        "spatial_shader": {
          "type": "glitch_lines",
          "intensity": 0.4,
          "max_lines": 5,
          "speed": 2.0,
          "pulse_color": {
            "type": "rgb",
            "r": 0,
            "g": 255,
            "b": 150
          },
          "seed": 42
        }
      }
