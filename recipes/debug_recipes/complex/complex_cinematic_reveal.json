        "exit": {
          "type": "noise_dither",
          "seed": 42,
          "matrix": "bayer8"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "crt",
          "scanline_strength": 0.6,
          "jitter": 0.3,
          "curvature": 0.15
