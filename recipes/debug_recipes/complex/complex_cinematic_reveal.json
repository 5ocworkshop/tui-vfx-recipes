{
  "schema_version": 1,
  "id": "debug.complex.cinematic_reveal",
  "title": "Debug: Cinematic Path Reveal",
  "description": "Tests PathReveal mask with spiral pattern and CRT filter for cinematic effects",
  "version": "1.0.0",
  "last_updated": "2025-12-30",
  "config": {
    "message": "CINEMATIC REVEAL",
    "layout": {
      "width": 60,
      "height": 9,
      "anchor": "center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 12000
    },
    "border": {
      "type": "double",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only",
      "effect": {
        "type": "scramble",
        "resolve_pace": 1.2,
        "charset": "matrix",
        "seed": 12345
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 3000,
        "easing": "cubic_out"
      },
      "exit": {
        "duration_ms": 2000,
        "easing": "cubic_in"
      },
      "mask": {
        "enter": {
          "type": "path_reveal",
          "path": {
            "type": "spiral",
            "rotations": 3.0,
            "direction": "clockwise"
          },
          "soft_edge": true
