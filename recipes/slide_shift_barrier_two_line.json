{
  "schema_version": 2,
  "id": "slide_shift_barrier_two_line",
  "title": "SlideShift Two-Line Split",
  "description": "Two-line stream where the upper line clears the barrier while the lower line stays below.",
  "version": "1.0.0",
  "last_updated": "2026-01-22",
  "config": {
    "message": "Upper stream\nLower stream",
    "layout": {
      "mode": "fixed",
      "width": 58,
      "height": 11,
      "anchor": "center",
      "wrap": false
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "border": {
      "type": "double",
      "padding": {
        "top": 2,
        "right": 3,
        "bottom": 2,
        "left": 3
      },
      "title": "Up!",
      "title_position": "top",
      "title_alignment": "center"
    },
    "content": {
      "mode": "loop",
      "effect": {
        "type": "slide_shift",
        "start_col": -22,
        "end_col": 26,
        "start_row": 2,
        "shift_col": 22,
        "shift_width": 3,
        "row_shift": -1,
        "line_mode": "block",
        "flow_mode": "flow_back"
      }
    },
    "time": {
      "loop": true,
      "loop_period_ms": 2400
    },
    "pipeline": {
      "animation_type": "none",
      "enter": {
        "duration_ms": 0
      },
      "exit": {
        "duration_ms": 0
      },
      "styles": [
        {
          "region": "All",
          "base_style": {
            "foreground": {
              "type": "light_gray"
            },
            "background": {
              "type": "rgb",
              "r": 10,
              "g": 20,
              "b": 24
            }
          }
        },
        {
          "region": "BorderOnly",
          "base_style": {
            "foreground": {
              "type": "rgb",
              "r": 200,
              "g": 240,
              "b": 200
            }
          }
        },
        {
          "region": "TextOnly",
          "base_style": {
            "foreground": {
              "type": "white"
            }
          }
        }
      ]
    }
  }
}
