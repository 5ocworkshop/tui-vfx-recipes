{
  "schema_version": 1,
  "id": "toolkit.sizzle.airmail_envelope",
  "title": "Airmail Envelope",
  "description": "A message arrives like a postcard: it rises in, flutters slightly, and washes with a soft travel-gradient before sealing shut.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
    "message": "New message received\nAirmail: Lisbon → Madeira",
    "layout": {
      "width": 54,
      "height": 5,
      "anchor": "top_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8500
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only",
      "effect": {
        "type": "typewriter",
        "speed_variance": 0.2
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 1700,
        "easing": "cubic_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 900,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "wipe",
          "direction": "bottom_to_top",
          "soft_edge": true
        },
        "exit": {
          "type": "wipe",
          "direction": "top_to_bottom",
          "soft_edge": true
        }
      },
      "sampler": {
        "enter": {
          "type": "sine_wave",
          "axis": "x",
          "amplitude": 0.8,
          "frequency": 0.12,
          "speed": 1.1,
          "phase": 0.0
        },
        "exit": {
          "type": "shredder",
          "stripe_width": 2,
          "odd_speed": 1.8,
          "even_speed": -0.6
        }
      },
      "filter": {
        "enter": {
          "type": "tint",
          "color": {
            "type": "light_blue"
          },
          "strength": 0.06,
          "apply_to": "both"
        },
        "exit": {
          "type": "tint",
          "color": {
            "type": "black"
          },
          "strength": 0.7,
          "apply_to": "both"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 20,
            "g": 20,
            "b": 35
          },
          "background": {
            "type": "rgb",
            "r": 245,
            "g": 245,
            "b": 240
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "linear_gradient",
            "gradient": {
              "stops": [
                [
                  0.0,
                  {
                    "type": "light_cyan"
                  }
                ],
                [
                  1.0,
                  {
                    "type": "light_yellow"
                  }
                ]
              ],
              "space": "rgb"
            },
            "angle_deg": 45.0
          }
        },
        "exit_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 2.2,
            "band_width": 1,
            "angle_deg": 0,
            "head": {
              "type": "light_magenta"
            },
            "tail": {
              "type": "black"
            }
          }
        }
      }
    }
  }
}
