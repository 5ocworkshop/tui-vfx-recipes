{
  "schema_version": 1,
  "id": "toolkit.sizzle.theremin_glide",
  "title": "Theremin Glide",
  "description": "A musical UI cue: the card ‘glides’ with liquid distortion while a diagonal shimmer pulses like a sustained note.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
    "message": "Volume: 68%\n(Scroll to adjust)",
    "layout": {
      "width": 32,
      "height": 5,
      "anchor": "middle_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 9000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 1700,
        "easing": "quad_in_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 900,
        "easing": "cubic_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "wipe",
          "direction": "left_to_right",
          "soft_edge": true
        },
        "exit": {
          "type": "wipe",
          "direction": "right_to_left",
          "soft_edge": true
        }
      },
      "sampler": {
        "enter": {
          "type": "sine_wave",
          "axis": "x",
          "amplitude": 1.3,
          "frequency": 0.18,
          "speed": 1.6,
          "phase": 0.5
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "vignette",
          "strength": 0.3,
          "radius": 0.8
        },
        "exit": {
          "type": "tint",
          "color": {
            "type": "black"
          },
          "strength": 0.7,
          "apply_to": "both"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 230,
            "g": 230,
            "b": 255
          },
          "background": {
            "type": "rgb",
            "r": 15,
            "g": 10,
            "b": 35
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "pulse_wave",
            "frequency": 1.7,
            "speed": 1.0,
            "color": {
              "type": "light_magenta"
            },
            "direction": "diagonal",
            "wavelength": 9.0
          }
        },
        "exit_effect": {
          "type": "pulse",
          "frequency": 2.6,
          "color": {
            "type": "light_cyan"
          }
        }
      }
    }
  }
}
