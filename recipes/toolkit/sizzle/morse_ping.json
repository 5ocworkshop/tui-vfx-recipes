{
  "schema_version": 1,
  "id": "toolkit.sizzle.morse_ping",
  "title": "Morse Ping",
  "description": "A playful comms cue: checker ‘dots’, unstable neon flicker, and a crisp CRT texture—feels like a radio room without losing legibility.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
    "message": "Ping received • RTT 42ms",
    "layout": {
      "width": 36,
      "height": 3,
      "anchor": "top_left"
    },
    "lifecycle": {
      "auto_dismiss_ms": 4200
    },
    "border": {
      "type": "plain",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 900,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 450,
        "easing": "cubic_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "checkers",
          "cell_size": 1
        },
        "exit": {
          "type": "wipe",
          "direction": "right_to_left",
          "soft_edge": false
        }
      },
      "sampler": {
        "enter": {
          "type": "crt_jitter",
          "intensity": 1.5,
          "speed_hz": 20.0,
          "decay_ms": 900
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "crt",
          "scanline_strength": 0.2,
          "glow": 0.35
        },
        "exit": {
          "type": "tint",
          "color": {
            "type": "black"
          },
          "strength": 0.7,
          "apply_to": "both"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "light_cyan"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "neon_flicker",
          "stability": 0.55
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "CubicIn"
        }
      }
    }
  }
}
