{
  "schema_version": 1,
  "id": "toolkit.sizzle.postcard_swoosh",
  "title": "Postcard Swoosh",
  "description": "A travel postcard arrives: diamond reveal like a postcard flip, a tiny ‘stamp’ ripple in the corner, then a closing sheen signature.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
