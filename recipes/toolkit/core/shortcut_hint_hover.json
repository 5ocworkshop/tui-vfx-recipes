{
  "schema_version": 1,
  "id": "toolkit.core.shortcut_hint_hover",
  "title": "Shortcut Hint Hover",
  "description": "A premium hint that feels ‘alive’ but not noisy: soft wipe + subtle hover + low-frequency pulse to suggest interactivity.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
    "message": "Hint: Press  Ctrl+K  to search",
    "layout": {
      "width": 36,
      "height": 3,
      "anchor": "bottom_left"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 900,
        "easing": "cubic_out",
        "motion_path": {
          "type": "hover",
          "amplitude": 0.35,
          "frequency": 25.132741
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 520,
        "easing": "cubic_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "wipe",
          "direction": "bottom_to_top",
          "soft_edge": true
        },
        "exit": {
          "type": "wipe",
          "direction": "top_to_bottom",
          "soft_edge": true
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "vignette",
          "strength": 0.2,
          "radius": 0.9
        },
        "exit": {
          "type": "tint",
          "color": {
            "type": "black"
          },
          "strength": 0.5,
          "apply_to": "both"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 240,
            "g": 240,
            "b": 240
          },
          "background": {
            "type": "rgb",
            "r": 30,
            "g": 30,
            "b": 38
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "pulse",
          "frequency": 0.9,
          "color": {
            "type": "light_cyan"
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "CubicIn"
        }
      }
    }
  }
}
