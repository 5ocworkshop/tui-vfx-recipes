{
  "schema_version": 1,
  "id": "toolkit.core.warning_beacon_banner",
  "title": "Warning Beacon Banner",
  "description": "A wide OS-style banner: vertical blinds open like safety shutters, then a calm beacon sweep crosses the surface.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
    "message": "⚠  Low disk space — 1.2 GB remaining",
    "layout": {
      "width": 80,
      "height": 3,
      "anchor": "top_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 6500
    },
    "border": {
      "type": "plain",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 700,
        "easing": "quad_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 460,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "blinds",
          "orientation": "vertical",
          "count": 16
        },
        "exit": {
          "type": "wipe",
          "direction": "bottom_to_top",
          "soft_edge": false
        }
      },
      "sampler": {
        "enter": {
          "type": "sine_wave",
          "axis": "y",
          "amplitude": 0.5,
          "frequency": 0.18,
          "speed": 1.2,
          "phase": 0.0
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "vignette",
          "strength": 0.15,
          "radius": 0.95
        },
        "exit": {
          "type": "tint",
          "color": {
            "type": "black"
          },
          "strength": 0.75,
          "apply_to": "both"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 20,
            "g": 20,
            "b": 20
          },
          "background": {
            "type": "rgb",
            "r": 255,
            "g": 210,
            "b": 80
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "pulse_wave",
            "frequency": 1.4,
            "speed": 1.6,
            "color": {
              "type": "rgb",
              "r": 60,
              "g": 120,
              "b": 200
            },
            "direction": "horizontal",
            "wavelength": 16.0
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "CubicIn"
        }
      }
    }
  }
}
