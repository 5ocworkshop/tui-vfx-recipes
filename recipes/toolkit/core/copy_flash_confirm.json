{
  "schema_version": 1,
  "id": "toolkit.core.copy_flash_confirm",
  "title": "Copy Flash Confirm",
  "description": "A fast, satisfying confirmation: tiny CRT stutter + brief invert flash on entry, then a clean retreat.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
    "message": "Copied to clipboard",
    "layout": {
      "width": 34,
      "height": 3,
      "anchor": "bottom_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 1800
    },
    "border": {
      "type": "plain",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 220,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 320,
        "easing": "cubic_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "wipe",
          "direction": "left_to_right",
          "soft_edge": false
        },
        "exit": {
          "type": "wipe",
          "direction": "right_to_left",
          "soft_edge": true
        }
      },
      "sampler": {
        "enter": {
          "type": "crt_jitter",
          "intensity": 1.8,
          "speed_hz": 45.0,
          "decay_ms": 220
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "invert",
          "apply_to": "both"
        },
        "exit": {
          "type": "dim",
          "factor": 0.1,
          "apply_to": "both"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "black"
          },
          "background": {
            "type": "rgb",
            "r": 210,
            "g": 250,
            "b": 255
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": null,
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "CubicIn"
        }
      }
    }
  }
}
