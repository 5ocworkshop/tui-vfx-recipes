{
  "schema_version": 1,
  "id": "toolkit.core.reconnect_ripple",
  "title": "Reconnect Ripple",
  "description": "A confident reconnect: portal-like iris + watery ripple + radiating pulse wave, then a clean soft wipe away.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
    "message": "Network restored\nAll services online",
    "layout": {
      "width": 46,
      "height": 5,
      "anchor": "top_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 5200
    },
    "border": {
      "type": "double",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only",
      "effect": {
        "type": "scramble",
        "resolve_pace": 0.75,
        "charset": "alphanumeric",
        "seed": 4242
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 1800,
        "easing": "quad_in_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 620,
        "easing": "cubic_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "iris",
          "shape": "circle",
          "soft_edge": true
        },
        "exit": {
          "type": "wipe",
          "direction": "top_to_bottom",
          "soft_edge": true
        }
      },
      "sampler": {
        "enter": {
          "type": "ripple",
          "amplitude": 1.4,
          "wavelength": 7.0,
          "speed": 1.7,
          "center": "center"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "vignette",
          "strength": 0.25,
          "radius": 0.8
        },
        "exit": {
          "type": "tint",
          "color": {
            "type": "black"
          },
          "strength": 0.65,
          "apply_to": "both"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 230,
            "g": 250,
            "b": 255
          },
          "background": {
            "type": "rgb",
            "r": 0,
            "g": 40,
            "b": 55
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "pulse_wave",
            "frequency": 2.1,
            "speed": 2.0,
            "color": {
              "type": "light_cyan"
            },
            "direction": "radial",
            "wavelength": 5.5
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "CubicIn"
        }
      }
    }
  }
}
