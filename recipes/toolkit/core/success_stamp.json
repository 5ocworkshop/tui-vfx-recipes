        "exit": {
          "type": "dissolve",
          "seed": 802,
          "chunk_size": 2
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "ripple",
          "amplitude": 0.9,
          "wavelength": 9.0,
          "speed": -1.2,
          "center": "center"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "dim",
          "factor": 0.25,
          "apply_to": "both"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 18,
            "g": 34,
            "b": 28
          },
          "background": {
            "type": "rgb",
            "r": 222,
            "g": 246,
            "b": 236
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "pulse",
          "frequency": 1.6,
          "color": {
            "type": "light_cyan"
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "CubicIn"
        }
      }
    }
  }
