{
  "schema_version": 1,
  "id": "toolkit.showcase.aurora_drift",
  "title": "Aurora Drift",
  "description": "A calm cinematic layer-cake: Bayer emergence, slow drifting distortion, and a gentle rainbow glaze—then an inward ripple like gravity folding light.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
    "message": "Midnight aurora\n— data stream calm —",
    "layout": {
      "width": 60,
      "height": 5,
      "anchor": "top_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 14000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 3200,
        "easing": "quad_in_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 1300,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "noise_dither",
          "seed": 120,
          "matrix": "bayer8"
        },
        "exit": {
          "type": "wipe",
          "direction": "right_to_left",
          "soft_edge": true
        }
      },
      "sampler": {
        "enter": {
          "type": "sine_wave",
          "axis": "x",
          "amplitude": 1.8,
          "frequency": 0.12,
          "speed": 0.45,
          "phase": 0.0
        },
        "exit": {
          "type": "ripple",
          "amplitude": 1.0,
          "wavelength": 14.0,
          "speed": -0.8,
          "center": "center"
        }
      },
      "filter": {
        "enter": {
          "type": "vignette",
          "strength": 0.35,
          "radius": 0.85
        },
        "exit": {
          "type": "tint",
          "color": {
            "type": "black"
          },
          "strength": 0.7,
          "apply_to": "both"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 240,
            "g": 240,
            "b": 240
          },
          "background": {
            "type": "rgb",
            "r": 0,
            "g": 10,
            "b": 18
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "rainbow",
          "speed": 0.9
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "CubicIn"
        }
      }
    }
  }
}
