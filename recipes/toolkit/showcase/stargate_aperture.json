{
  "schema_version": 1,
  "id": "toolkit.showcase.stargate_aperture",
  "title": "Stargate Aperture",
  "description": "A sci-fi portal: circular iris opens, high-energy ripple distorts, magenta ring pulses, then an invert zap ends the scene.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
