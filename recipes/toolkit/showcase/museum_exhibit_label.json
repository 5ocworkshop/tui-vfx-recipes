          "type": "tint",
          "color": {
            "type": "black"
          },
          "strength": 0.85,
          "apply_to": "both"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 30,
            "g": 30,
            "b": 35
          },
          "background": {
            "type": "rgb",
            "r": 245,
            "g": 245,
            "b": 245
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 0.3,
            "band_width": 3,
            "angle_deg": 90,
            "head": {
              "type": "white"
            },
            "tail": {
              "type": "rgb",
              "r": 200,
              "g": 200,
              "b": 210
            }
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "CubicIn"
        }
