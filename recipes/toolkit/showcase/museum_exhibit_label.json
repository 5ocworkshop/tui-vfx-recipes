{
  "schema_version": 1,
  "id": "toolkit.showcase.museum_exhibit_label",
  "title": "Museum Exhibit Label",
  "description": "Nordic museum calm with polish: slow reveal through soft box iris, a glass-like sheen pass, and a dignified blackout.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
    "message": "EXHIBIT 14\nNordic Minimalism\n— 1968 —",
    "layout": {
      "width": 34,
      "height": 7,
      "anchor": "center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 18000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only",
      "effect": {
        "type": "typewriter",
        "speed_variance": 0.2
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 3600,
        "easing": "cubic_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 1400,
        "easing": "cubic_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "iris",
          "shape": "box",
          "soft_edge": true
        },
        "exit": {
