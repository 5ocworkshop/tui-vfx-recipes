{
  "schema_version": 1,
  "id": "toolkit.showcase.mountaineering_weather_front",
  "title": "Mountaineering Weather Front",
  "description": "A weather map as motion design: the front sweeps in via gradient, wind warps the field, and pressure bands drift vertically.",
  "version": "0.1.0",
  "last_updated": "2025-12-23",
  "config": {
