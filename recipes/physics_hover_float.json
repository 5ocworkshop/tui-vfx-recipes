{
  "schema_version": 1,
  "id": "physics.hover_float",
  "title": "Hover Float",
  "description": "Notification floats in gently with a hovering, weightless motion",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
    "message": "Floating by...",
    "layout": {
      "width": 26,
      "height": 3,
      "anchor": "middle_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 5000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 1200,
        "easing": "sine_in_out",
        "motion_path": {
          "type": "hover"
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_bottom",
          "margin_cells": 6
        }
      },
      "exit": {
        "duration_ms": 1000,
        "easing": "sine_in_out",
        "motion_path": {
          "type": "hover"
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_top",
          "margin_cells": 6
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 200,
            "g": 220,
            "b": 255
          },
          "background": {
            "type": "rgb",
            "r": 30,
            "g": 35,
            "b": 50
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "both",
          "ease": "SineOut"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "SineIn"
        }
      }
    },
    "requires_primitives": []
  }
}
