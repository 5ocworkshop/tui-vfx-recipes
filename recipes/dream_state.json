{
  "schema_version": 1,
  "id": "notifications.dream_state",
  "title": "Dream State",
  "description": "Wobbly sine wave distortion with dissolve",
  "version": "2.0.0",
  "last_updated": "2025-12-18",
  "config": {
    "message": "ENTERING DREAM STATE...",
    "layout": {
      "width": 30,
      "height": 4,
      "anchor": "center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 9000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 3000,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 700,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "dissolve",
          "seed": 9001,
          "chunk_size": 1
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "sine_wave",
          "axis": "y",
          "amplitude": 1.2,
          "frequency": 0.7,
          "speed": 1.0,
          "phase": 0.0
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "light_magenta"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "dim"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "foreground",
          "ease": "Linear"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.dissolve_params",
      "sampler.sinewave_params"
    ]
  }
}
