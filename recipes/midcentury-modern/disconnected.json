{
  "schema_version": 1,
  "id": "midcentury.disconnected",
  "title": "Disconnected",
  "description": "Signal lost. Muted gray with empty circle title, fading presence with iris close.",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
    "message": "○ Connection lost",
    "layout": {
      "width": 34,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8000
    },
    "border": {
      "type": "rounded",
      "trim": "none",
      "title": "○ OFFLINE",
      "title_position": "top",
      "title_alignment": "center"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 450,
        "easing": "sine_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 650,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "iris",
          "shape": "circle",
          "soft_edge": true
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "tint",
          "color": {
            "type": "rgb",
            "r": 80,
            "g": 80,
            "b": 85
          },
          "strength": 0.2,
          "apply_to": "both"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 180,
            "g": 180,
            "b": 185
          },
          "background": {
            "type": "rgb",
            "r": 105,
            "g": 105,
            "b": 105
          },
          "added_modifiers": [
            "dim"
          ],
          "removed_modifiers": []
        },
        "enter_effect": null,
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    }
  }
}
