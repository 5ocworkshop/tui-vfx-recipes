        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "linear_gradient",
            "gradient": {
              "stops": [
                [
                  0.0,
                  {
                    "type": "rgb",
                    "r": 70,
                    "g": 70,
                    "b": 180
                  }
                ],
                [
                  0.5,
                  {
                    "type": "rgb",
                    "r": 40,
                    "g": 40,
                    "b": 140
                  }
                ],
                [
                  1.0,
                  {
                    "type": "rgb",
                    "r": 25,
                    "g": 25,
                    "b": 112
                  }
                ]
              ],
              "space": "rgb"
            },
            "angle_deg": 45.0
          }
