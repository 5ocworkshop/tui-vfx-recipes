{
  "schema_version": 1,
  "id": "midcentury.deploy",
  "title": "Deploy",
  "description": "Sputnik moment. Midnight blue with starburst title, atomic age grandeur.",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
    "message": "🚀 Deployed to production",
    "layout": {
      "width": 38,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 6000
    },
    "border": {
      "type": "thick",
      "trim": "none",
      "title": "★ DEPLOY ★",
      "title_position": "top",
      "title_alignment": "center"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 550,
