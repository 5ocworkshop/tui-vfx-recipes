        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 255,
            "g": 250,
            "b": 240
          },
          "background": {
            "type": "rgb",
            "r": 25,
            "g": 25,
            "b": 112
          },
          "added_modifiers": [
            "bold",
            "underlined"
          ],
          "removed_modifiers": []
