{
  "schema_version": 1,
  "id": "midcentury.git_conflict",
  "title": "Git Conflict",
  "description": "Collision course. High contrast coral with lightning bolt, thick border demands resolution.",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
    "message": "⚡ Merge conflict in 2 files",
    "layout": {
      "width": 40,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 12000
    },
    "border": {
      "type": "thick",
      "trim": "none",
      "title": "CONFLICT",
      "title_position": "top",
      "title_alignment": "center"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 240,
        "easing": "expo_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 600,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "checkers",
          "cell_size": 2
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 255,
            "g": 255,
            "b": 240
          },
          "background": {
            "type": "rgb",
            "r": 255,
            "g": 127,
            "b": 80
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": null,
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    }
  }
}
