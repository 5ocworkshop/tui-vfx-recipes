{
  "schema_version": 1,
  "id": "notifications.retro_terminal",
  "title": "Retro Terminal",
  "description": "Typewriter content with dim filter",
  "version": "2.0.0",
  "last_updated": "2025-12-18",
  "config": {
    "message": "LOGIN SUCCESSFUL... WELCOME BACK, ROOT USER.",
    "layout": {
      "width": 32,
      "height": 4,
      "anchor": "bottom_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 9000
    },
    "border": {
      "type": "plain",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only",
      "effect": {
        "type": "typewriter",
        "speed_variance": 0.15
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 3000,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 800,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "blinds",
          "orientation": "horizontal",
          "count": 10
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "dim",
          "factor": 0.35,
          "apply_to": "background"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "light_green"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "foreground",
          "ease": "Linear"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.blinds_params"
    ]
  }
}
