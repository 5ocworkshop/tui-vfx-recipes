        "dwell_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 0.67,
            "band_width": 40,
            "angle_deg": 0.0,
            "head": {
              "type": "rgb",
              "r": 255,
              "g": 180,
              "b": 50
            },
            "tail": {
              "type": "rgb",
              "r": 180,
              "g": 100,
              "b": 20
            },
            "direction": "ping_pong",
            "apply_to": "foreground",
            "blend_strength": 1.0
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "QuadIn"
        }
      }
    },
    "requires_primitives": [
      "shader.glisten_band",
      "region.border_only"
    ]
  }
}
