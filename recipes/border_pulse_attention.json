{
  "schema_version": 1,
  "id": "border.pulse_attention",
  "title": "Border Pulse (Attention)",
  "description": "Border pulses with warm amber glow to draw attention. Ping-pong creates breathing effect.",
  "version": "1.0.0",
  "last_updated": "2025-12-29",
  "config": {
    "message": "⚠ ATTENTION\n\nAction Required",
    "layout": {
      "width": 28,
      "height": 6,
      "anchor": "center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "time": {
      "loop": true,
      "loop_period_ms": 1500
    },
    "border": {
      "type": "double",
      "trim": "none",
      "center_content": true
    },
    "pipeline": {
      "enter": {
        "duration_ms": 300,
        "easing": "quad_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 250,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 255,
            "g": 200,
            "b": 100
          },
          "background": {
            "type": "rgb",
            "r": 25,
            "g": 15,
            "b": 5
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 0.67,
            "band_width": 40,
            "angle_deg": 0.0,
            "head": {
              "type": "rgb",
              "r": 255,
              "g": 180,
              "b": 50
            },
            "tail": {
              "type": "rgb",
              "r": 180,
              "g": 100,
              "b": 20
            },
            "direction": "ping_pong",
            "apply_to": "foreground",
            "blend_strength": 1.0
          }
