{
  "schema_version": 1,
  "id": "scandi_edge.disconnected",
  "title": "Disconnected",
  "description": "Fading signal. Desaturated steel gray, tint filter drains color, iris exit closes the connection.",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
    "message": "Connection lost",
    "layout": {
      "width": 32,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 450,
        "easing": "sine_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 600,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "iris",
          "shape": "circle",
          "soft_edge": true
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "tint",
          "color": {
            "type": "rgb",
            "r": 55,
            "g": 58,
            "b": 62
          },
          "strength": 0.15,
          "apply_to": "both"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 165,
            "g": 172,
            "b": 180
          },
          "background": {
            "type": "rgb",
            "r": 58,
            "g": 62,
            "b": 68
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": null,
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    }
  }
}
