{
  "schema_version": 1,
  "id": "scandi_edge.connected",
  "title": "Connected",
  "description": "Electric link. Vivid cyan with quick upward bounce, pulsing energy signals active connection.",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
    "message": "Connected to server",
    "layout": {
      "width": 32,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 2500
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 300,
        "easing": "back_out",
        "motion_path": {
          "type": "arc",
          "bulge": -0.16
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 220,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 15,
            "g": 45,
            "b": 55
          },
          "background": {
            "type": "rgb",
            "r": 45,
            "g": 195,
            "b": 205
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "band_width": 3,
            "speed": 1.4,
            "angle_deg": 15.0,
            "head": {
              "type": "rgb",
              "r": 150,
              "g": 245,
              "b": 255
            },
            "tail": {
              "type": "rgb",
              "r": 75,
              "g": 215,
              "b": 225
            }
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "CubicOut"
        }
      }
    }
  }
}
