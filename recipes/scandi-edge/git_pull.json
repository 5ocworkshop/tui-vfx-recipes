{
  "schema_version": 1,
  "id": "scandi_edge.git_pull",
  "title": "Git Pull",
  "description": "Inward reception. Complementary mauve-rose with settling arc, wipe draws content in.",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
