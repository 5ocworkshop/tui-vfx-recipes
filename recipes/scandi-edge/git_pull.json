        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "band_width": 5,
            "speed": 0.55,
            "angle_deg": 40.0,
            "head": {
              "type": "rgb",
              "r": 195,
              "g": 155,
              "b": 175
