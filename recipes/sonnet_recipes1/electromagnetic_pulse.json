{
  "schema_version": 1,
  "id": "notifications.electromagnetic_pulse",
  "title": "Electromagnetic Pulse",
  "description": "Radio wave interference pattern with horizontal glitch lines and rapid pulse waves. Simulates electromagnetic disturbance with scan-line artifacts and color separation. Technical and aggressive.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "⚡ EMP DETECTED - SYSTEMS COMPROMISED",
    "layout": {
      "width": 44,
      "height": 4,
      "anchor": "top_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 5000
    },
    "border": {
      "type": "plain",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 1200,
        "easing": "linear",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 400,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "blinds",
          "orientation": "horizontal",
          "count": 12
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "light_yellow"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glitch_lines",
            "seed": 4444,
            "intensity": 0.8,
            "max_lines": 8,
            "speed": 3.0,
            "flash_chance": 0.1,
            "pulse_color": {
              "type": "rgb",
              "r": 255,
              "g": 100,
              "b": 0
            },
            "pulse_speed": 2.0
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.blinds",
      "shader.glitch_lines"
    ]
  }
}
