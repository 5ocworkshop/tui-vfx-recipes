{
  "schema_version": 1,
  "id": "notifications.progress_heartbeat",
  "title": "Progress Heartbeat",
  "description": "Steady, reassuring pulse for long-running tasks. Breathes with a gentle sine wave sampler and soft color pulse, creating a living, organic feel that says 'I'm working'. Calming rather than anxious.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "Processing...",
    "layout": {
      "width": 24,
      "height": 3,
      "anchor": "bottom_left"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 800,
        "easing": "quad_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 500,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "wipe",
          "direction": "left_to_right",
          "soft_edge": true
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "sine_wave",
          "axis": "x",
          "amplitude": 0.3,
          "frequency": 0.4,
          "speed": 0.5,
          "phase": 0.0
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "green"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "pulse",
          "frequency": 0.8,
          "color": {
            "type": "light_green"
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "sampler.sinewave_params",
      "style.effect.pulse"
    ]
  }
}
