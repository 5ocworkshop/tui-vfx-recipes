{
  "schema_version": 1,
  "id": "notifications.thermal_vision",
  "title": "Thermal Vision",
  "description": "Heat signature reveal with iris mask, rainbow color cycle, and radial pulse. Emerges from thermal imaging scan, cycling through heat spectrum colors. Scientific and otherworldly.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "THERMAL SIGNATURE ACQUIRED",
