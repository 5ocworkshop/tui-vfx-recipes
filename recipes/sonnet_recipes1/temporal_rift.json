{
  "schema_version": 1,
  "id": "notifications.temporal_rift",
  "title": "Temporal Rift",
  "description": "Time-distortion effect with shredder sampler and scrambled text. Vertical strips slide at different speeds creating a temporal tear in reality, while text scrambles and resolves. Time itself becoming unstable.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "TEMPORAL ANOMALY DETECTED",
    "layout": {
      "width": 40,
      "height": 4,
      "anchor": "bottom_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8000
    },
    "border": {
      "type": "plain",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only",
      "effect": {
        "type": "scramble",
        "resolve_pace": 0.6,
        "charset": "alphanumeric",
        "seed": 7777
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 2500,
        "easing": "linear",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 600,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "shredder",
          "stripe_width": 3,
          "odd_speed": 2.0,
          "even_speed": -1.5
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "magenta"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "rainbow",
          "speed": 2.5
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "sampler.shredder",
      "content.scramble",
      "style.effect.rainbow"
    ]
  }
}
