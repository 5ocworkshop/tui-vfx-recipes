{
  "schema_version": 1,
  "id": "notifications.spectral_haunting",
  "title": "Spectral Haunting",
  "description": "Ghostly appearance with noise dither mask, gentle sine distortion, and dim filter. Materializes like a phantom from static, wavering and translucent. Eerie and atmospheric.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "Presence detected...",
    "layout": {
      "width": 28,
      "height": 4,
      "anchor": "top_left"
    },
    "lifecycle": {
      "auto_dismiss_ms": 10000
    },
    "border": {
      "type": "plain",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 3000,
        "easing": "linear",
        "motion_path": {
          "type": "hover",
          "amplitude": 0.4,
          "frequency": 15.0
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 2000,
        "easing": "linear",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "noise_dither",
          "seed": 666,
          "matrix": "bayer8"
        },
        "exit": {
          "type": "dissolve",
          "seed": 667,
          "chunk_size": 2
        }
      },
      "sampler": {
        "enter": {
          "type": "sine_wave",
          "axis": "x",
          "amplitude": 0.8,
          "frequency": 0.5,
          "speed": 0.3,
          "phase": 0.0
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "dim",
          "factor": 0.5,
          "apply_to": "both"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 180,
            "g": 200,
            "b": 220
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "pulse",
          "frequency": 0.5,
          "color": {
            "type": "white"
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.noise_dither",
      "mask.dissolve_params",
      "sampler.sinewave_params",
      "filter.dim",
      "style.effect.pulse"
    ]
  }
}
