{
  "schema_version": 1,
  "id": "notifications.focus_anchor",
  "title": "Focus Anchor",
  "description": "Draws the eye with a radial pulse wave that settles into steady presence. The wave emanates from center like a dropped stone in water, then stabilizes. Ideal for capturing attention for important updates without jarring disruption.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "Review Required",
    "layout": {
      "width": 28,
      "height": 3,
      "anchor": "top_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 1200,
        "easing": "quad_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 400,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "light_blue"
          },
          "background": {
            "type": "rgb",
            "r": 10,
            "g": 15,
            "b": 25
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "pulse_wave",
            "frequency": 1.2,
            "speed": 2.0,
            "color": {
              "type": "cyan"
            },
            "direction": "radial",
            "wavelength": 8.0
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "shader.pulse_wave"
    ]
  }
}
