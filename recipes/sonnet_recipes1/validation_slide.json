{
  "schema_version": 1,
  "id": "notifications.validation_slide",
  "title": "Validation Slide",
  "description": "Smooth horizontal entry for form validation feedback. Slides in from the side with soft wipe mask, creating a polished, professional appearance. Neutral timing that feels responsive without being rushed.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "Email format invalid",
    "layout": {
      "width": 32,
      "height": 2,
      "anchor": "top_left"
    },
    "lifecycle": {
      "auto_dismiss_ms": 4000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 400,
        "easing": "quad_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 300,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "wipe",
          "direction": "left_to_right",
          "soft_edge": true
        },
        "exit": {
          "type": "wipe",
          "direction": "right_to_left",
          "soft_edge": false
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "light_red"
          },
          "background": {
            "type": "rgb",
            "r": 40,
            "g": 10,
            "b": 10
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "both",
          "ease": "Linear"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.wipe"
    ]
  }
}
