{
  "schema_version": 1,
  "id": "notifications.ocean_depths",
  "title": "Ocean Depths",
  "description": "Deep water emergence with ripple sampler and slow vertical sine waves. Rises from the depths with concentric ripples and gentle undulating motion, like a message surfacing from the abyss. Mysterious and fluid.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
