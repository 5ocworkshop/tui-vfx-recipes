{
  "schema_version": 1,
  "id": "notifications.priority_stack",
  "title": "Priority Stack",
  "description": "Urgent but not jarring notification with vertical blind reveal and attention-grabbing pulse. Demands attention through motion and color without being aggressive. Professional urgency.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "Action Required: Review pending approval",
    "layout": {
      "width": 42,
      "height": 3,
      "anchor": "top_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "border": {
      "type": "double",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 500,
        "easing": "quad_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 300,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "blinds",
          "orientation": "vertical",
          "count": 8
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "yellow"
          },
          "background": {
            "type": "rgb",
            "r": 40,
            "g": 30,
            "b": 0
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "pulse",
          "frequency": 2.0,
          "color": {
            "type": "light_yellow"
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.blinds",
      "style.effect.pulse"
    ]
  }
}
