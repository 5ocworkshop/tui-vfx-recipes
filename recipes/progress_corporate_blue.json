{
  "schema_version": 1,
  "id": "progress.corporate_blue",
  "title": "Corporate Blue",
  "description": "Professional blue gradient sweep. Subtle, elegant activity indicator for business applications.",
  "version": "1.0.0",
  "last_updated": "2025-12-29",
  "config": {
    "message": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
    "layout": {
      "width": 40,
      "height": 1,
      "anchor": "bottom_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "time": {
      "loop": true,
      "loop_period_ms": 2000
    },
    "border": {
      "type": "none",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 400,
        "easing": "quad_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 300,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 40,
            "g": 80,
            "b": 140
          },
          "background": {
            "type": "reset"
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 0.5,
            "band_width": 8,
            "angle_deg": 0.0,
            "head": {
              "type": "rgb",
              "r": 100,
              "g": 160,
              "b": 230
            },
            "tail": {
              "type": "rgb",
              "r": 50,
              "g": 100,
              "b": 180
            },
            "direction": "forward",
            "apply_to": "foreground",
            "blend_strength": 0.8
          }
        },
        "dwell_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 0.5,
            "band_width": 8,
            "angle_deg": 0.0,
            "head": {
              "type": "rgb",
              "r": 100,
              "g": 160,
              "b": 230
            },
            "tail": {
              "type": "rgb",
              "r": 50,
              "g": 100,
              "b": 180
            },
            "direction": "forward",
            "apply_to": "foreground",
            "blend_strength": 0.8
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "QuadIn"
        }
      }
    },
    "requires_primitives": [
      "shader.glisten_band"
    ]
  }
}
