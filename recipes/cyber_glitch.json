{
  "schema_version": 1,
  "id": "notifications.cyber_glitch",
  "title": "Cyber-Glitch",
  "description": "Binary scramble with brief italic shift glitch and sine distortion",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "INCOMING ENCRYPTED DATA",
    "layout": {
      "width": 42,
      "height": 4,
      "anchor": "bottom_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 10000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only",
      "effect": {
        "type": "scramble_glitch_shift",
        "resolve_pace": 0.8,
        "charset": "binary",
        "scramble_seed": 777,
        "shift_amount": 5,
        "glitch_start": 0.3,
        "glitch_end": 0.7
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 7000,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 700,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "dissolve",
          "seed": 777,
          "chunk_size": 1
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "sine_wave",
          "axis": "y",
          "amplitude": 1.0,
          "frequency": 0.85,
          "speed": 1.2,
          "phase": 0.0
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "light_cyan"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "glitch",
          "seed": 1337,
          "intensity": 0.5
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.dissolve_params",
      "sampler.sinewave_params",
      "content.scramble_glitch_shift"
    ]
  }
}
