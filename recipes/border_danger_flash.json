{
  "schema_version": 1,
  "id": "border.danger_flash",
  "title": "Border Danger Flash",
  "description": "Rapid red flashing border for critical alerts. High urgency attention-getter.",
  "version": "1.0.0",
  "last_updated": "2025-12-29",
  "config": {
    "message": "⚠ CRITICAL ERROR\n\nImmediate action required!",
    "layout": {
      "width": 32,
      "height": 6,
      "anchor": "center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "time": {
      "loop": true,
      "loop_period_ms": 600
    },
    "border": {
      "type": "thick",
      "trim": "none",
      "center_content": true
    },
    "pipeline": {
      "enter": {
        "duration_ms": 200,
        "easing": "quad_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 200,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 255,
            "g": 100,
            "b": 100
          },
          "background": {
            "type": "rgb",
            "r": 30,
            "g": 5,
            "b": 5
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 1.67,
            "band_width": 80,
            "angle_deg": 0.0,
            "head": {
              "type": "rgb",
              "r": 255,
              "g": 60,
              "b": 60
            },
            "tail": {
              "type": "rgb",
              "r": 180,
              "g": 20,
              "b": 20
            },
            "direction": "ping_pong",
            "apply_to": "foreground",
            "blend_strength": 1.0
          }
        },
        "dwell_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 1.67,
            "band_width": 80,
            "angle_deg": 0.0,
            "head": {
              "type": "rgb",
              "r": 255,
              "g": 60,
              "b": 60
            },
            "tail": {
              "type": "rgb",
              "r": 180,
              "g": 20,
              "b": 20
            },
            "direction": "ping_pong",
            "apply_to": "foreground",
            "blend_strength": 1.0
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "QuadIn"
        }
      }
    },
    "requires_primitives": [
      "shader.glisten_band",
      "region.border_only"
    ]
  }
}
