{
  "schema_version": 1,
  "id": "notifications.task_processing",
  "title": "Task Processing",
  "description": "Barber pole activity stripe with scrolling text",
  "version": "2.0.0",
  "last_updated": "2025-12-18",
  "config": {
    "message": "COMPILING ASSETS... PLEASE WAIT...",
    "layout": {
      "width": 40,
      "height": 3,
      "anchor": "bottom_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 12000
    },
    "time": {
      "loop": true,
      "loop_period_ms": 2000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "content": {
      "mode": "loop",
      "effect": {
        "type": "marquee",
        "speed": 1.0,
        "width": 36
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 500,
        "easing": "quad_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_bottom",
          "margin_cells": 1
        }
      },
      "exit": {
        "duration_ms": 700,
        "easing": "quad_in",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_bottom",
          "margin_cells": 1
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "dim",
          "factor": 0.25,
          "apply_to": "background"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "white"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "barber_pole",
            "speed": 2.0,
            "stripe_width": 2,
            "gap_width": 3,
            "color": {
              "type": "blue"
            }
          }
        },
        "dwell_effect": {
          "type": "spatial",
          "shader": {
            "type": "barber_pole",
            "speed": 2.0,
            "stripe_width": 2,
            "gap_width": 3,
            "color": {
              "type": "blue"
            }
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "QuadIn"
        }
      }
    },
    "requires_primitives": [
      "style.shader.barber_pole",
      "style.spatial_per_cell",
      "content.marquee_params",
      "time.looping"
    ]
  }
}
