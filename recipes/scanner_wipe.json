{
  "schema_version": 1,
  "id": "notifications.scanner_wipe",
  "title": "Data Scanner",
  "description": "Typewriter content with wipe mask",
  "version": "2.0.0",
  "last_updated": "2025-12-18",
  "config": {
    "message": "PROCESSING BIOMETRICS... IDENTITY VERIFIED",
    "layout": {
      "width": 34,
      "height": 4,
      "anchor": "bottom_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only",
      "effect": {
        "type": "typewriter",
        "speed_variance": 0.1
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 2500,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 700,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "wipe",
          "direction": "left_to_right",
          "soft_edge": true
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "dim",
          "factor": 0.25,
          "apply_to": "background"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "white"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "foreground",
          "ease": "Linear"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.wipe_direction"
    ]
  }
}
