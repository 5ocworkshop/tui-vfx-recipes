{
  "schema_version": 1,
  "id": "notifications.pill_notification",
  "title": "Pill Notification",
  "description": "Compact rounded notification that floats up from bottom center with a gentle bounce. Perfect for confirmations and status updates.",
  "version": "1.0.0",
  "last_updated": "2025-12-24",
  "config": {
    "message": "Action completed",
    "layout": {
      "width": 22,
      "height": 3,
      "anchor": "bottom_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 3000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 350,
        "easing": "back_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_bottom",
          "margin_cells": 2
        }
      },
      "exit": {
        "duration_ms": 220,
        "easing": "quad_in",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_bottom",
          "margin_cells": 0
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "wipe",
          "direction": "bottom_to_top",
          "soft_edge": true
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 248,
            "g": 250,
            "b": 252
          },
          "background": {
            "type": "rgb",
            "r": 59,
            "g": 130,
            "b": 246
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "both",
          "ease": "CubicOut"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "QuadIn"
        }
      }
    }
  }
}
