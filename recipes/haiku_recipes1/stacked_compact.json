{
  "schema_version": 1,
  "id": "notifications.stacked_compact",
  "title": "Stacked Compact",
  "description": "Small, compact notification designed for stacking multiple notifications vertically. Each takes minimal space while remaining readable and distinct.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "✓ Item added",
    "layout": {
      "width": 16,
      "height": 1,
      "anchor": "bottom_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 3000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 300,
        "easing": "back_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 250,
        "easing": "back_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "green"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "foreground",
          "ease": "Linear"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": []
  }
}
