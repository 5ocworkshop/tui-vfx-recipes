{
  "schema_version": 1,
  "id": "notifications.warning_caution",
  "title": "Warning Caution",
  "description": "Balanced warning notification with yellow tone. Gets attention through color and dissolve, but less aggressive than errors. Perfect for maintenance warnings or action needed.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "⚠ Warning: Disk space low",
    "layout": {
      "width": 30,
      "height": 3,
      "anchor": "bottom_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 5000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 700,
        "easing": "quad_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 400,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "dissolve",
          "seed": 2001,
          "chunk_size": 2
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "yellow"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "foreground",
          "ease": "Linear"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.dissolve_params"
    ]
  }
}
