{
  "schema_version": 1,
  "id": "notifications.aurora_cascade",
  "title": "Aurora Cascade",
  "description": "Artistic aurora borealis effect with rainbow color waves and gentle horizontal sine distortion. Creates a serene, magical atmosphere perfect for celebrations or artistic highlights.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "✨ EXCELLENCE UNLOCKED ✨",
    "layout": {
      "width": 32,
      "height": 4,
      "anchor": "top_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 7000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 3200,
        "easing": "sine_in_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 1000,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "sine_wave",
          "axis": "x",
          "amplitude": 0.8,
          "frequency": 0.5,
          "speed": 0.8,
          "phase": 0.0
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "magenta"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "rainbow",
          "speed": 1.5
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "sampler.sinewave_params",
      "style.effect.rainbow"
    ]
  }
}
