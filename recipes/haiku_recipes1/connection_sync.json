{
  "schema_version": 1,
  "id": "notifications.connection_sync",
  "title": "Connection Sync",
  "description": "Light blue notification that indicates network or data synchronization. Uses subtle hover motion to suggest ongoing activity without visual noise.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "🔗 Syncing with server...",
    "layout": {
      "width": 26,
      "height": 2,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 500,
        "easing": "linear",
        "motion_path": {
          "type": "hover",
          "amplitude": 0.08,
          "frequency": 15.0
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 300,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "light_blue"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "foreground",
          "ease": "Linear"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": []
  }
}
