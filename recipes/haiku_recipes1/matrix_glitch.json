{
  "schema_version": 1,
  "id": "notifications.matrix_glitch",
  "title": "Matrix Glitch",
  "description": "Cinematic sci-fi effect with binary scramble, green glow, and sine wave distortion. Perfect for dramatic system notifications, easter eggs, or hacker aesthetics.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "SYSTEM BREACH: CODE INJECTION DETECTED",
    "layout": {
      "width": 45,
      "height": 4,
      "anchor": "center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only",
      "effect": {
        "type": "scramble_glitch_shift",
        "resolve_pace": 0.6,
        "charset": "binary",
        "scramble_seed": 666,
        "shift_amount": 3,
        "glitch_start": 0.2,
        "glitch_end": 0.5
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 3000,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 800,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "dissolve",
          "seed": 666,
          "chunk_size": 1
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "sine_wave",
          "axis": "y",
          "amplitude": 1.5,
          "frequency": 0.9,
          "speed": 1.4,
          "phase": 0.0
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "green"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "glitch",
          "seed": 666,
          "intensity": 0.8
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.dissolve_params",
      "sampler.sinewave_params",
      "content.scramble_glitch_shift",
      "style.effect.glitch"
    ]
  }
}
