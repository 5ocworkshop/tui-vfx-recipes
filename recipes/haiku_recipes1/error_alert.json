{
  "schema_version": 1,
  "id": "notifications.error_alert",
  "title": "Error Alert",
  "description": "Attention-grabbing error notification with red pulse and dissolve effect. Gets user's attention without being overly alarming. Stays visible until dismissed.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "✗ Error: Operation failed",
    "layout": {
      "width": 32,
      "height": 3,
      "anchor": "top_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 600,
        "easing": "quad_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 400,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "dissolve",
          "seed": 1001,
          "chunk_size": 1
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "red"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "foreground",
          "ease": "Linear"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.dissolve_params"
    ]
  }
}
