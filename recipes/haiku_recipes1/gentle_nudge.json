{
  "schema_version": 1,
  "id": "notifications.gentle_nudge",
  "title": "Gentle Nudge",
  "description": "Subtle hover motion with soft fade-in. Perfect for non-intrusive notifications that gently draw attention without disrupting workflow.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "Tip: Use Ctrl+S to save your work",
    "layout": {
      "width": 32,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 4000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 500,
        "easing": "quad_out",
        "motion_path": {
          "type": "hover",
          "amplitude": 0.1,
          "frequency": 20.0
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 300,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "gray"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "foreground",
          "ease": "Linear"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": []
  }
}
