{
  "schema_version": 1,
  "id": "notifications.progress_pulse",
  "title": "Progress Pulse",
  "description": "Pulsing blue notification for ongoing operations. Color waves indicate activity and forward progress. Non-dismissible until task completes.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "⟳ Processing your request...",
    "layout": {
      "width": 28,
      "height": 2,
      "anchor": "bottom_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 400,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 300,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "cyan"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "pulse_wave",
            "frequency": 1.5,
            "speed": 1.2,
            "color": {
              "type": "blue"
            },
            "direction": "radial",
            "wavelength": 8.0
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "shader.pulse_wave"
    ]
  }
}
