{
  "schema_version": 1,
  "id": "notifications.update_available",
  "title": "Update Available",
  "description": "Cyan notification for software or content updates. Uses dissolve effect for visibility and soft pulse to indicate new information. Stays visible until dismissed.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "▲ Update available - tap to install",
    "layout": {
      "width": 35,
      "height": 2,
      "anchor": "top_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 800,
        "easing": "quad_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 400,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "dissolve",
          "seed": 4001,
          "chunk_size": 2
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "cyan"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "pulse_wave",
            "frequency": 1.0,
            "speed": 1.0,
            "color": {
              "type": "cyan"
            },
            "direction": "radial",
            "wavelength": 9.0
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "mask.dissolve_params",
      "shader.pulse_wave"
    ]
  }
}
