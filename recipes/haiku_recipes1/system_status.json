{
  "schema_version": 1,
  "id": "notifications.system_status",
  "title": "System Status",
  "description": "Quiet gray notification for background process updates. Minimal visual impact allows user to focus on main task while staying informed.",
  "version": "1.0.0",
  "last_updated": "2025-12-22",
  "config": {
    "message": "🔄 Database sync in progress",
    "layout": {
      "width": 30,
      "height": 2,
      "anchor": "bottom_left"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 600,
        "easing": "linear",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 300,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "dark_gray"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "foreground",
          "ease": "Linear"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": []
  }
}
