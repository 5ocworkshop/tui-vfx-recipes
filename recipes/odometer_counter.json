{
  "schema_version": 1,
  "id": "notifications.odometer_counter",
  "title": "Odometer Counter",
  "description": "Rolling digits for high scores or stats",
  "version": "2.0.0",
  "last_updated": "2025-12-18",
  "config": {
    "message": "SCORE: 999999",
    "layout": {
      "width": 20,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8000
    },
    "time": {
      "loop": true,
      "loop_period_ms": 1600
    },
    "border": {
      "type": "plain",
      "trim": "none"
    },
    "content": {
      "mode": "loop",
      "effect": {
        "type": "odometer"
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 1800,
        "easing": "quad_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_right",
          "margin_cells": 1
        }
      },
      "exit": {
        "duration_ms": 700,
        "easing": "quad_in",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_right",
          "margin_cells": 1
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "TextOnly",
        "base_style": {
          "foreground": {
            "type": "white"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "foreground",
          "ease": "QuadOut"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "QuadIn"
        },
        "spatial_shader": {
          "type": "highlighter",
          "color": {
            "type": "yellow"
          }
        }
      }
    },
    "requires_primitives": [
      "content.odometer",
      "style.shader.highlighter",
      "style.spatial_per_cell",
      "time.looping"
    ]
  }
}
