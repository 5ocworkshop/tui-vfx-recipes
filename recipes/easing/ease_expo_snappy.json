{
  "schema_version": 1,
  "id": "examples.expo_snappy_notification",
  "title": "Snappy Notification",
  "description": "Quick notification using ExpoOut for instant appearance feel with CircIn for smooth exit",
  "version": "1.0.0",
  "last_updated": "2025-12-24",
  "config": {
    "message": "💡 Quick Action Complete!",
    "layout": {
      "width": 40,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 2000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 300,
        "easing": "expo_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_right",
          "margin_cells": 0
        }
      },
      "exit": {
        "duration_ms": 200,
        "easing": "circ_in",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_right",
          "margin_cells": 0
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 180,
            "g": 220,
            "b": 220
          },
          "background": {
            "type": "rgb",
            "r": 26,
            "g": 26,
            "b": 46
          },
          "added_modifiers": [
            "Bold"
          ],
          "removed_modifiers": []
        }
      }
    }
  }
}
