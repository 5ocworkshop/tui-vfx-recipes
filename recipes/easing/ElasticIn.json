{
  "schema_version": 1,
  "id": "easing.ElasticIn",
  "title": "Elastic In Easing",
  "description": "Oscillates before arriving - spring wind-up effect",
  "version": "2.0.0",
  "last_updated": "2025-12-24",
  "config": {
    "message": "━━━ ELASTIC IN ━━━\n\nSpring oscillation\nBouncy wind-up",
    "layout": {
      "width": 58,
      "height": 7,
      "anchor": "top_left"
    },
    "lifecycle": {
      "auto_dismiss_ms": 3500
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 1000,
        "easing": "elastic_in",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_left",
          "margin_cells": 0
        }
      },
      "exit": {
        "duration_ms": 500,
        "easing": "elastic_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_left",
          "margin_cells": 0
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 240,
            "g": 240,
            "b": 240
          },
          "background": {
            "type": "rgb",
            "r": 40,
            "g": 40,
            "b": 40
          },
          "added_modifiers": [
            "Bold"
          ],
          "removed_modifiers": []
        }
      }
    }
  }
}
