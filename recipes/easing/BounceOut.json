{
  "schema_version": 1,
  "id": "easing.BounceOut",
  "title": "Bounce Out Easing",
  "description": "Settles with multiple bounces - like a ball dropping",
  "version": "2.0.0",
  "last_updated": "2025-12-24",
  "config": {
    "message": "━━━ BOUNCE OUT ━━━\n\nMultiple bounces\nGravity-like settling",
    "layout": {
      "width": 55,
      "height": 7,
      "anchor": "bottom_left"
    },
    "lifecycle": {
      "auto_dismiss_ms": 3500
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 1000,
        "easing": "bounce_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_bottom",
          "margin_cells": 0
        }
      },
      "exit": {
        "duration_ms": 500,
        "easing": "bounce_in",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_bottom",
          "margin_cells": 0
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 180,
            "g": 220,
            "b": 220
          },
          "background": {
            "type": "rgb",
            "r": 26,
            "g": 26,
            "b": 46
          },
          "added_modifiers": [
            "Bold"
          ],
          "removed_modifiers": []
        }
      }
    }
  }
}
