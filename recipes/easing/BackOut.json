{
  "schema_version": 1,
  "id": "easing.BackOut",
  "title": "Back Out Easing",
  "description": "Overshoots past target then settles back - emphasis and anticipation",
  "version": "2.0.0",
  "last_updated": "2025-12-24",
  "config": {
    "message": "━━━ BACK OUT ━━━\n\nOvershoots → pulls back\nCreates emphasis",
    "layout": {
      "width": 55,
      "height": 7,
      "anchor": "top_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 3000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 700,
        "easing": "back_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_top",
          "margin_cells": 0
        }
      },
      "exit": {
        "duration_ms": 400,
        "easing": "back_in",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_top",
          "margin_cells": 0
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 180,
            "g": 220,
            "b": 220
          },
          "background": {
            "type": "rgb",
            "r": 26,
            "g": 26,
            "b": 46
          },
          "added_modifiers": [
            "Bold"
          ],
          "removed_modifiers": []
        }
      }
    }
  }
}
