{
  "schema_version": 1,
  "id": "border.sweep_counter",
  "title": "Border Sweep (Counter-Clockwise)",
  "description": "Light sweeps around the border counter-clockwise. Reverse direction variant for visual variety.",
  "version": "1.0.0",
  "last_updated": "2025-12-29",
  "config": {
    "message": "⟲ Reversing...\n\nPlease wait",
    "layout": {
      "width": 30,
      "height": 7,
      "anchor": "center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "time": {
      "loop": true,
      "loop_period_ms": 2000
    },
    "border": {
      "type": "rounded",
      "trim": "none",
      "center_content": true
    },
    "pipeline": {
      "enter": {
        "duration_ms": 400,
        "easing": "quad_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 300,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 200,
            "g": 170,
            "b": 240
          },
          "background": {
            "type": "rgb",
            "r": 20,
            "g": 15,
            "b": 25
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 0.5,
            "band_width": 8,
            "angle_deg": -45.0,
            "head": {
              "type": "rgb",
              "r": 200,
              "g": 150,
              "b": 255
            },
            "tail": {
              "type": "rgb",
              "r": 100,
              "g": 60,
              "b": 180
            },
            "direction": "reverse",
            "apply_to": "foreground",
            "blend_strength": 1.0
          }
        },
        "dwell_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 0.5,
            "band_width": 8,
            "angle_deg": -45.0,
            "head": {
              "type": "rgb",
              "r": 200,
              "g": 150,
              "b": 255
            },
            "tail": {
              "type": "rgb",
              "r": 100,
              "g": 60,
              "b": 180
            },
            "direction": "reverse",
            "apply_to": "foreground",
            "blend_strength": 1.0
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "QuadIn"
        }
      }
    },
    "requires_primitives": [
      "shader.glisten_band",
      "region.border_only"
    ]
  }
