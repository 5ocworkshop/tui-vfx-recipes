{
  "schema_version": 1,
  "id": "notifications.hologram_checkers",
  "title": "Hologram Scan",
  "description": "Cyan spatial shader with checkers mask",
  "version": "2.0.0",
  "last_updated": "2025-12-18",
  "config": {
    "message": "SCANNING FOR THREATS... NO MALWARE DETECTED",
    "layout": {
      "width": 38,
      "height": 4,
      "anchor": "bottom_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 8000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 1500,
        "easing": "quad_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 650,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "checkers",
          "cell_size": 2
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "sine_wave",
          "axis": "x",
          "amplitude": 0.7,
          "frequency": 1.0,
          "speed": 1.3,
          "phase": 0.0
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "light_cyan"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "linear_gradient",
            "gradient": {
              "stops": [
                [
                  0.0,
                  {
                    "type": "light_cyan"
                  }
                ],
                [
                  1.0,
                  {
                    "type": "rgb",
                    "r": 0,
                    "g": 120,
                    "b": 120
                  }
                ]
              ],
              "space": "rgb"
            },
            "angle_deg": 90.0
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "QuadIn"
        }
      }
    },
    "requires_primitives": [
      "style.spatial_per_cell",
      "sampler.sinewave_params"
    ]
  }
}
