{
  "schema_version": 1,
  "id": "progress.breathing_bar",
  "title": "Breathing Bar",
  "description": "Horizontal bar that pulses with a slow breathing rhythm. Calming blue gradient sweep.",
  "version": "1.0.0",
  "last_updated": "2025-12-29",
  "config": {
    "message": "████████████████",
    "layout": {
      "width": 16,
      "height": 1,
      "anchor": "bottom_center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 0
    },
    "time": {
      "loop": true,
      "loop_period_ms": 3333
    },
    "border": {
      "type": "none",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 400,
        "easing": "sine_in_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 300,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 30,
            "g": 60,
            "b": 120
          },
          "background": {
            "type": "reset"
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 0.3,
            "band_width": 20,
            "angle_deg": 0.0,
            "head": {
              "type": "rgb",
              "r": 100,
              "g": 150,
              "b": 255
            },
            "tail": {
              "type": "rgb",
              "r": 40,
              "g": 80,
              "b": 160
            },
            "direction": "ping_pong",
            "apply_to": "foreground",
            "blend_strength": 0.9
          }
        },
        "dwell_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "speed": 0.3,
            "band_width": 20,
            "angle_deg": 0.0,
            "head": {
              "type": "rgb",
              "r": 100,
              "g": 150,
              "b": 255
            },
            "tail": {
              "type": "rgb",
              "r": 40,
              "g": 80,
              "b": 160
            },
            "direction": "ping_pong",
            "apply_to": "foreground",
            "blend_strength": 0.9
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "SineIn"
        }
      }
    },
    "requires_primitives": [
      "shader.glisten_band"
    ]
  }
}
