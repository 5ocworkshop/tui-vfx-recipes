{
  "schema_version": 1,
  "id": "notifications.whisper_toast",
  "title": "Whisper Toast",
  "description": "Minimal borderless notification that appears with subtle fade and micro-slide. Modern, unobtrusive design for non-critical updates.",
  "version": "1.0.0",
  "last_updated": "2025-12-24",
  "config": {
    "message": "Changes saved",
    "layout": {
      "width": 24,
      "height": 3,
      "anchor": "bottom_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 2500
    },
    "border": {
      "type": "none",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 280,
        "easing": "cubic_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_right",
          "margin_cells": 0
        }
      },
      "exit": {
        "duration_ms": 180,
        "easing": "quad_in",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_right",
          "margin_cells": 0
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 230,
            "g": 235,
            "b": 240
          },
          "background": {
            "type": "rgb",
            "r": 45,
            "g": 50,
            "b": 58
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "both",
          "ease": "CubicOut"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "QuadIn"
        }
      }
    }
  }
}
