{
  "schema_version": 1,
  "id": "physics.projectile_toss",
  "title": "Projectile Toss",
  "description": "Notification tosses in with ballistic arc, like throwing a paper airplane",
  "version": "1.0.0",
  "last_updated": "2025-12-31",
  "config": {
    "message": "Incoming!",
    "layout": {
      "width": 28,
      "height": 3,
      "anchor": "center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 4000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 800,
        "easing": "linear",
        "motion_path": {
          "type": "projectile",
          "arc_height": -8.0,
          "gravity": 400.0
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_left",
          "margin_cells": 5
        }
      },
      "exit": {
        "duration_ms": 600,
        "easing": "linear",
        "motion_path": {
          "type": "projectile",
          "arc_height": 6.0,
          "gravity": 600.0
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_right",
          "margin_cells": 5
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 255,
            "g": 253,
            "b": 208
          },
          "background": {
            "type": "rgb",
            "r": 0,
            "g": 128,
            "b": 128
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "both",
          "ease": "QuadOut"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "QuadIn"
        }
      }
    },
    "requires_primitives": []
  }
}
