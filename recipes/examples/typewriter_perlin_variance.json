{
  "schema_version": 1,
  "id": "examples.typewriter_perlin_variance",
  "title": "Typewriter with Perlin Variance",
  "description": "Smooth organic typing effect using noise-based speed variance for gradual rhythm changes.",
  "version": "2.0.0",
  "last_updated": "2025-12-24",
  "config": {
    "message": "Watch the typing speed flow like waves...",
    "layout": {
      "mode": "fixed",
      "width": 50,
      "height": 4,
      "anchor": "center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 6000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only",
      "effect": {
        "type": "typewriter",
        "speed_variance": 0.2
      }
    },
    "pipeline": {
      "animation_type": "none",
      "enter": {
        "duration_ms": 2500,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 500,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "dwell": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "dwell": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "dwell": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "green"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": null,
        "dwell_effect": null,
        "exit_effect": null
      }
    }
  }
}
