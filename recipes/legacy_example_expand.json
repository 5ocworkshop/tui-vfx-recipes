{
  "schema_version": 1,
  "id": "notifications.legacy_example_expand",
  "title": "Legacy: Expand",
  "description": "Expand/Collapse animation",
  "version": "2.0.0",
  "last_updated": "2025-12-18",
  "config": {
    "message": "Expanding!",
    "layout": {
      "width": 30,
      "height": 3,
      "anchor": "bottom_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 4000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 550,
        "easing": "quad_out",
        "rect_scale": {
          "type": "rect_scale",
          "origin": "center",
          "min_width": 3,
          "min_height": 1
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 650,
        "easing": "quad_in",
        "rect_scale": {
          "type": "rect_scale",
          "origin": "center",
          "min_width": 3,
          "min_height": 1
        },
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "white"
          },
          "background": {
            "type": "rgb",
            "r": 12,
            "g": 14,
            "b": 20
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "both",
          "ease": "QuadOut"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "QuadIn"
        }
      }
    },
    "requires_primitives": [
      "geometry.rect_scale"
    ]
  }
}
