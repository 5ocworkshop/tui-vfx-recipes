{
  "schema_version": 1,
  "id": "notifications.signal_seismic_alert",
  "title": "Seismic Alert",
  "description": "Earthquake warning with violent shaking that rapidly decays",
  "version": "1.0.0",
  "last_updated": "2025-12-24",
  "config": {
