      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "dwell": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "yellow"
          },
          "background": {
            "type": "rgb",
            "r": 100,
            "g": 50,
            "b": 0
