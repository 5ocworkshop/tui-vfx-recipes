{
  "schema_version": 1,
  "id": "notifications.slide_in_bounce",
  "title": "_Slide In + Bounce",
  "description": "Slide from offscreen with bounce landing (JSON port)",
  "version": "2.0.0",
  "last_updated": "2025-12-18",
  "config": {
    "message": "Slide in + bounce",
    "layout": {
      "anchor": "bottom_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 2500
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 900,
        "easing": "quad_out",
        "motion_path": {
          "type": "bounce",
          "bounces": 3,
          "decay": 2.0
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_bottom",
          "margin_cells": 1
        }
      },
      "exit": {
        "duration_ms": 750,
        "easing": "quad_in",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_bottom",
          "margin_cells": 1
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "white"
          },
          "background": {
            "type": "rgb",
            "r": 12,
            "g": 14,
            "b": 20
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "both",
          "ease": "QuadOut"
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "QuadIn"
        }
      }
    },
    "requires_primitives": [
      "geometry.path.bounce"
    ]
  }
}
