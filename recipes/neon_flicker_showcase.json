{
  "schema_version": 1,
  "id": "notifications.neon_flicker_showcase",
  "title": "Neon Flicker Showcase",
  "description": "Demonstrates NeonFlicker shader with row-level flickering for damaged neon sign effect.",
  "version": "1.0.0",
  "last_updated": "2025-12-23",
  "config": {
