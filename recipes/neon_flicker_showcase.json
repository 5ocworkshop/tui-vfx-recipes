        "duration_ms": 700,
        "easing": "quad_out",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 500,
        "easing": "quad_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
