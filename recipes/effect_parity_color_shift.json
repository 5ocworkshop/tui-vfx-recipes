      },
      "exit": {
        "duration_ms": 400,
        "easing": "cubic_in"
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 255,
            "g": 100,
            "b": 100
          },
          "background": {
            "type": "rgb",
            "r": 20,
            "g": 20,
            "b": 30
          }
        },
        "enter_effect": {
          "type": "color_shift",
          "hue_shift": 120.0,
          "saturation_shift": 0.2,
          "lightness_shift": 0.1
        }
