{
  "schema_version": 1,
  "id": "showcase.effect_parity_color_shift",
  "title": "Color Shift Effect",
  "description": "Demonstrates the new ColorShift style effect with HSL manipulation",
  "version": "1.0.0",
  "last_updated": "2025-12-26",
  "config": {
    "message": "COLOR SHIFTING!",
    "layout": {
      "anchor": "bottom_right",
      "width": 25,
      "height": 4
    },
    "lifecycle": {
      "auto_dismiss_ms": 5000
