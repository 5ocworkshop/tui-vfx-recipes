{
  "schema_version": 1,
  "id": "scandi.deploy",
  "title": "Deploy",
  "description": "Momentous arrival. Deep fjord blue with confident upward arc, bold border signals importance.",
  "version": "2.0.0",
  "last_updated": "2025-12-30",
  "config": {
    "message": "Deployed to production",
    "layout": {
      "width": 36,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 6000
    },
    "border": {
      "type": "thick",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 550,
        "easing": "cubic_out",
        "motion_path": {
          "type": "arc",
          "bulge": -0.12
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 450,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "wipe",
          "direction": "left_to_right",
          "soft_edge": true
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 248,
            "g": 250,
            "b": 255
          },
          "background": {
            "type": "rgb",
            "r": 45,
            "g": 72,
            "b": 92
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "linear_gradient",
            "gradient": {
              "stops": [
                [
                  0.0,
                  {
                    "type": "rgb",
                    "r": 55,
                    "g": 85,
                    "b": 108
                  }
                ],
                [
                  1.0,
                  {
                    "type": "rgb",
                    "r": 45,
                    "g": 72,
                    "b": 92
                  }
                ]
              ],
              "space": "rgb"
            },
            "angle_deg": 0.0
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "SineOut"
        }
      }
    }
  }
}
