{
  "schema_version": 1,
  "id": "scandi.git_pull",
  "title": "Git Pull",
  "description": "Inward reception. Soft lavender with settling arc, receiving updates gracefully.",
  "version": "2.0.0",
  "last_updated": "2025-12-30",
  "config": {
    "message": "Pulled 3 commits",
    "layout": {
      "width": 34,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 3500
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 450,
        "easing": "sine_out",
        "motion_path": {
          "type": "arc",
          "bulge": 0.1
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 320,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "wipe",
          "direction": "left_to_right",
          "soft_edge": true
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 250,
            "g": 248,
            "b": 252
          },
          "background": {
            "type": "rgb",
            "r": 105,
            "g": 95,
            "b": 115
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "band_width": 4,
            "speed": 0.5,
            "angle_deg": 5.0,
            "head": {
              "type": "rgb",
              "r": 155,
              "g": 145,
              "b": 168
            },
            "tail": {
              "type": "rgb",
              "r": 125,
              "g": 115,
              "b": 135
            }
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "SineOut"
        }
      }
    }
  }
}
