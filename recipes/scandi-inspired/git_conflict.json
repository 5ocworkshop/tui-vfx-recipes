{
  "schema_version": 1,
  "id": "scandi.git_conflict",
  "title": "Git Conflict",
  "description": "Attention required. Coral clay with firm linear entry, double border emphasizes blockage.",
  "version": "2.0.0",
  "last_updated": "2025-12-30",
  "config": {
    "message": "Merge conflict in 2 files",
    "layout": {
      "width": 38,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 12000
    },
    "border": {
      "type": "double",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 300,
        "easing": "cubic_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 500,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "dissolve",
          "seed": 17,
          "chunk_size": 1
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 42,
            "g": 38,
            "b": 35
          },
          "background": {
            "type": "rgb",
            "r": 198,
            "g": 125,
            "b": 108
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": null,
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "Linear"
        }
      }
    }
  }
}
