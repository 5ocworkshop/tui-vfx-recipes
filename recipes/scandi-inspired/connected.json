{
  "schema_version": 1,
  "id": "scandi.connected",
  "title": "Connected",
  "description": "Swift confirmation. Nordic teal with quick upward arc, fast glisten signals active link.",
  "version": "2.0.0",
  "last_updated": "2025-12-30",
  "config": {
    "message": "Connected to server",
    "layout": {
      "width": 32,
      "height": 3,
      "anchor": "top_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 2500
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 340,
        "easing": "cubic_out",
        "motion_path": {
          "type": "arc",
          "bulge": -0.1
        },
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 250,
        "easing": "sine_in",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "rgb",
            "r": 250,
            "g": 252,
            "b": 252
          },
          "background": {
            "type": "rgb",
            "r": 58,
            "g": 102,
            "b": 105
          },
          "added_modifiers": [],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "spatial",
          "shader": {
            "type": "glisten_band",
            "band_width": 3,
            "speed": 1.1,
            "angle_deg": 0.0,
            "head": {
              "type": "rgb",
              "r": 120,
              "g": 165,
              "b": 168
            },
            "tail": {
              "type": "rgb",
              "r": 85,
              "g": 130,
              "b": 132
            }
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "both",
          "ease": "SineOut"
        }
      }
    }
  }
}
