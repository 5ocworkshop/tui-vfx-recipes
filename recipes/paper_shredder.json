{
  "schema_version": 1,
  "id": "notifications.paper_shredder",
  "title": "Paper Shredder",
  "description": "Notification shreds downwards on exit",
  "version": "2.0.0",
  "last_updated": "2025-12-18",
  "config": {
    "message": "CONFIDENTIAL DESTROYED",
    "layout": {
      "width": 30,
      "height": 6,
      "anchor": "center"
    },
    "lifecycle": {
      "auto_dismiss_ms": 3500
    },
    "border": {
      "type": "plain",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 500,
        "easing": "quad_out",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_top",
          "margin_cells": 1
        }
      },
      "exit": {
        "duration_ms": 2000,
        "easing": "linear",
        "motion_path": {
          "type": "linear"
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_bottom",
          "margin_cells": 1
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "shredder",
          "stripe_width": 2,
          "odd_speed": 4.0,
          "even_speed": 1.0
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "white"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "fade_in",
          "apply_to": "foreground",
          "ease": "QuadOut"
        },
        "exit_effect": {
          "type": "pulse",
          "frequency": 1.0,
          "color": {
            "type": "red"
          }
        }
      }
    },
    "requires_primitives": [
      "sampler.shredder",
      "mask.dissolve_params"
    ]
  }
}
