{
  "schema_version": 1,
  "id": "notifications.smooth_arc",
  "title": "Smooth Rainbow Arc",
  "description": "Arc path with rainbow hue shift",
  "version": "2.0.0",
  "last_updated": "2025-12-18",
  "config": {
    "message": "Achievement Unlocked: Master of Motion!",
    "layout": {
      "width": 34,
      "height": 3,
      "anchor": "bottom_right"
    },
    "lifecycle": {
      "auto_dismiss_ms": 6000
    },
    "border": {
      "type": "rounded",
      "trim": "none"
    },
    "pipeline": {
      "enter": {
        "duration_ms": 2000,
        "easing": "quad_out",
        "motion_path": {
          "type": "arc",
          "bulge": 0.6
        },
        "snapping": {
          "type": "round"
        },
        "from": {
          "type": "offscreen",
          "direction": "from_right",
          "margin_cells": 1
        }
      },
      "exit": {
        "duration_ms": 800,
        "easing": "quad_in",
        "motion_path": {
          "type": "arc",
          "bulge": 0.3
        },
        "snapping": {
          "type": "round"
        },
        "to": {
          "type": "offscreen",
          "direction": "from_right",
          "margin_cells": 1
        }
      },
      "mask": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "white"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "rainbow",
          "speed": 1.6
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "QuadIn"
        }
      }
    },
    "requires_primitives": [
      "geometry.path.arc_params"
    ]
  }
}
