{
  "schema_version": 1,
  "id": "notifications.system_boot",
  "title": "System Boot",
  "description": "Retro CRT scanlines with typewriter text",
  "version": "2.0.0",
  "last_updated": "2025-12-18",
  "config": {
    "message": "BIOS CHECK... [OK]",
    "layout": {
      "width": 30,
      "height": 4,
      "anchor": "top_left"
    },
    "lifecycle": {
      "auto_dismiss_ms": 6000
    },
    "border": {
      "type": "plain",
      "trim": "none"
    },
    "content": {
      "mode": "enter_only",
      "effect": {
        "type": "typewriter",
        "speed_variance": 0.2
      }
    },
    "pipeline": {
      "enter": {
        "duration_ms": 2000,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "exit": {
        "duration_ms": 700,
        "easing": "linear",
        "snapping": {
          "type": "round"
        }
      },
      "mask": {
        "enter": {
          "type": "wipe",
          "direction": "top_to_bottom",
          "soft_edge": true
        },
        "exit": {
          "type": "none"
        }
      },
      "sampler": {
        "enter": {
          "type": "crt",
          "scanline_strength": 0.35,
          "jitter": 0.12,
          "curvature": 0.15
        },
        "exit": {
          "type": "none"
        }
      },
      "filter": {
        "enter": {
          "type": "none"
        },
        "exit": {
          "type": "none"
        }
      },
      "style": {
        "region": "All",
        "base_style": {
          "foreground": {
            "type": "light_green"
          },
          "background": {
            "type": "black"
          },
          "added_modifiers": [
            "bold"
          ],
          "removed_modifiers": []
        },
        "enter_effect": {
          "type": "pulse",
          "frequency": 8.0,
          "color": {
            "type": "light_green"
          }
        },
        "exit_effect": {
          "type": "fade_out",
          "apply_to": "foreground",
          "ease": "Linear"
        }
      }
    },
    "requires_primitives": [
      "sampler.crt",
      "mask.wipe_direction"
    ]
  }
}
